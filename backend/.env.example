# Database Configuration
DATABASE_URL=postgresql://trading_user:password@localhost/ai_trading_platform

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Blockchain RPC URLs (EVM Chains)
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/your-api-key
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/your-api-key
OPTIMISM_RPC=https://opt-mainnet.g.alchemy.com/v2/your-api-key
BSC_RPC=https://bsc-dataseed.binance.org/
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
BASE_RPC=https://mainnet.base.org

# Solana RPC
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Testnet RPCs (for development)
ETHEREUM_TESTNET_RPC=https://eth-sepolia.g.alchemy.com/v2/your-api-key
POLYGON_TESTNET_RPC=https://polygon-mumbai.g.alchemy.com/v2/your-api-key
ARBITRUM_TESTNET_RPC=https://arb-sepolia.g.alchemy.com/v2/your-api-key

# DEX Aggregator API Keys
ONEINCH_API_KEY=your-1inch-api-key
JUPITER_API_KEY=your-jupiter-api-key
LIFI_API_KEY=your-lifi-api-key

# Price Data API Keys
COINGECKO_API_KEY=your-coingecko-api-key
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key

# External API URLs
ONEINCH_BASE_URL=https://api.1inch.dev/swap/v6.0
JUPITER_BASE_URL=https://quote-api.jup.ag/v6
LIFI_BASE_URL=https://li.quest/v1
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
BINANCE_BASE_URL=https://api.binance.com/api/v3

# MEV Protection
FLASHBOTS_RPC=https://rpc.flashbots.net
MEV_BLOCKER_RPC=https://rpc.mevblocker.io

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=30

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Trading Configuration
DEFAULT_SLIPPAGE_TOLERANCE=0.5
MAX_SLIPPAGE_TOLERANCE=5.0
HIGH_VALUE_THRESHOLD=10000
DAILY_LIMIT_DEFAULT=100000

# AI Configuration
SIGNAL_CONFIDENCE_THRESHOLD=70
CONCENTRATION_RISK_THRESHOLD=50

# Multi-AI Provider API Keys
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# AI Provider Settings
AI_ENVIRONMENT=development
AI_DEBUG=false
AI_MODEL_CACHE=./models
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token